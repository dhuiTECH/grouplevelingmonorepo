{
  "name": "my-turborepo",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "web": "pnpm --filter web dev",
    "mobile": "pnpm --filter mobile start",
    "kill": "taskkill /F /IM node.exe"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.10",
    "typescript": "5.9.2"
  }
}
